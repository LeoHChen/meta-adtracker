# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your values.
# Never commit a real .env (it's already in .gitignore).
# ---------------------------------------------------------------------------

# --- Notion ---
# Internal integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=

# The target database id (created by `python -m src.setup_notion`, or copied
# from the database URL). Share the database with your integration first.
NOTION_DATABASE_ID=

# --- Behaviour (all optional) ---
# Path to the Meta CSV export. Usually passed as a command-line argument
# instead: `python -m src.sync path/to/export.csv`
CSV_PATH=

# Only sync ads whose spend over the window is at least this amount. Default 0.
# Ignored if the export has no spend column.
MIN_SPEND=0

# Set to "true" to preview the parsed metrics without writing to Notion.
DRY_RUN=false
