# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your values for local runs.
# In GitHub Actions these are provided as repository secrets instead
# (Settings -> Secrets and variables -> Actions). Never commit a real .env.
# ---------------------------------------------------------------------------

# --- Meta (Facebook) Marketing API ---
# A long-lived (or system-user) access token with `ads_read` permission.
META_ACCESS_TOKEN=

# Your ad account id. May be given with or without the `act_` prefix; both work.
# Find it in Ads Manager -> Account Overview, or in the URL (act_XXXXXXXXXX).
META_AD_ACCOUNT_ID=

# Graph API version to call. Bump this to the latest supported version from
# https://developers.facebook.com/docs/graph-api/changelog if it is deprecated.
META_API_VERSION=v21.0

# --- Notion ---
# Internal integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=

# The target database id (created by setup_notion.py, or copied from the
# database URL). Share the database with your integration first.
NOTION_DATABASE_ID=

# --- Behaviour (all optional) ---
# How many days back the weekly window covers (ending yesterday). Default 7.
LOOKBACK_DAYS=7

# Only sync ads whose spend over the window is at least this amount. Default 0.
MIN_SPEND=0

# Set to "true" to print the fetched metrics without writing to Notion.
DRY_RUN=false
